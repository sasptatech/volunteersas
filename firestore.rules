rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function myProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isSuperadmin() {
      return isSignedIn() && myProfile().isSuperadmin == true;
    }
    function isAdmin() {
      return isSignedIn() && (myProfile().isAdmin == true || myProfile().isSuperadmin == true);
    }
    function isStoreAdmin() {
      return isSignedIn() && (myProfile().isStoreAdmin == true || myProfile().isSuperadmin == true);
    }
    function isAnyAdminTier() {
      return isSignedIn() && (myProfile().isAdmin == true || myProfile().isStoreAdmin == true || myProfile().isSuperadmin == true);
    }
    function isEventAdmin(eventId) {
      let ev = get(/databases/$(database)/documents/events/$(eventId)).data;
      return isSignedIn() && (request.auth.uid in ev.adminUids || isSuperadmin());
    }

    // ---- users ----
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Users can edit their own profile, but never grant themselves admin tiers.
      allow update: if isSignedIn() && request.auth.uid == userId
        && request.resource.data.isAdmin == resource.data.isAdmin
        && request.resource.data.isStoreAdmin == resource.data.isStoreAdmin
        && request.resource.data.isSuperadmin == resource.data.isSuperadmin;
      // Only a superadmin can change admin-tier flags. Deletion is allowed
      // for a superadmin (removing someone else) or the user themself
      // (self-service account deletion).
      allow update: if isSuperadmin();
      allow delete: if isSuperadmin() || request.auth.uid == userId;
    }

    // ---- events ----
    match /events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isAnyAdminTier();
      allow update, delete: if isEventAdmin(eventId);
    }

    // ---- general event signups ----
    match /signups/{signupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.uid;
      // Self-removal, the event's own admin(s) un-RSVPing someone, or superadmin.
      allow update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.uid ||
        isEventAdmin(resource.data.eventId) ||
        isSuperadmin()
      );
    }

    // ---- PTA Cafe shift signups ----
    match /cafeSignups/{signupId} {
      allow read: if isSignedIn();
      // Self sign-up, or a Store Admin creating an unclaimed extra slot (uid: null).
      allow create: if isSignedIn() && (
        request.auth.uid == request.resource.data.uid ||
        (isStoreAdmin() && request.resource.data.uid == null)
      );
      // Owner managing their own, a Store Admin managing any, or a volunteer
      // claiming a currently-unclaimed extra slot by setting their own uid.
      allow update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.uid ||
        isStoreAdmin() ||
        (resource.data.uid == null && request.auth.uid == request.resource.data.uid)
      );
    }

    // ---- volunteer slot sign-ups and item sign-ups (per-event) ----
    match /eventSlotSignups/{signupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.uid;
      allow update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.uid ||
        isEventAdmin(resource.data.eventId) ||
        isSuperadmin()
      );
    }
    match /eventItemSignups/{signupId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.uid;
      allow update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.uid ||
        isEventAdmin(resource.data.eventId) ||
        isSuperadmin()
      );
    }

    // ---- hours (admin-only visibility; users can still log their own) ----
    match /hours/{hourId} {
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.uid;
      allow read, update, delete: if isAnyAdminTier();
    }

    // ---- event/cafe chat messages ----
    match /chatMessages/{msgId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.uid;
      // Author can delete their own message; relevant admin tier can moderate.
      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.uid ||
        (resource.data.scope == 'cafe' && isStoreAdmin()) ||
        (resource.data.scope == 'event' && isEventAdmin(resource.data.eventId)) ||
        isSuperadmin()
      );
    }

    // ---- in-app notifications ----
    match /notifications/{notifId} {
      allow read, update: if isSignedIn() && request.auth.uid == resource.data.to;
      allow create: if isSignedIn();
    }

    // ---- audit log (superadmin visibility only) ----
    match /auditLog/{logId} {
      allow read: if isSuperadmin();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.actorUid;
    }

    // ---- PTA Cafe menu + day overrides (Store Admin only) ----
    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isStoreAdmin();
    }
    match /cafeDayOverrides/{date} {
      allow read: if isSignedIn();
      allow write: if isStoreAdmin();
    }

    // ---- removed-member archive (superadmin only) ----
    match /removedMemberArchive/{docId} {
      allow read, write: if isSuperadmin();
    }
  }
}
